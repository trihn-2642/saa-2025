#----------------------------------------------------------
# Supabase Environment Variables
#----------------------------------------------------------
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_secret_key

#----------------------------------------------------------
# Google OAuth (optional, for Supabase Auth)
#   Get these from https://console.cloud.google.com/apis/credentials
#----------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

#----------------------------------------------------------
# Countdown - Prelaunch page
#   Target datetime the countdown counts down to (ISO 8601).
#   Falls back to a hardcoded constant when unset/invalid.
#----------------------------------------------------------
NEXT_PUBLIC_COUNTDOWN_TARGET=2026-06-30T09:00:00+07:00
