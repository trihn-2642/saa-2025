#----------------------------------------------------------
# Supabase
#   From Supabase Dashboard → Project Settings → API.
#   Both are NEXT_PUBLIC_* on purpose: the app talks to Supabase
#   from the browser (createBrowserClient), so the URL + anon key
#   are embedded in the client bundle. The anon key is public by
#   design — security is enforced by Row Level Security (RLS),
#   not by hiding the key. Never expose the service_role secret.
#----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

#----------------------------------------------------------
# Countdown - Prelaunch page
#   Target datetime the countdown counts down to (ISO 8601).
#   Falls back to a hardcoded constant when unset/invalid.
#----------------------------------------------------------
NEXT_PUBLIC_COUNTDOWN_TARGET=2026-06-30T09:00:00+07:00
